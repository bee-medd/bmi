<resources>
    <style name="AppTheme" parent="Theme.Material3.Light.NoActionBar">
        <item name="colorPrimary">@color/md3_primary</item>
        <item name="colorOnPrimary">@color/md3_on_primary</item>
        <item name="colorSecondary">@color/md3_secondary</item>
        <item name="colorSurface">@color/md3_surface</item>
        <item name="android:windowBackground">@color/md3_background</item>
        <item name="android:statusBarColor">@color/md3_surface</item>
        <item name="android:windowLightStatusBar">true</item>
    </style>

    <!-- MD3 Button Style: Rounded and Tonal -->
    <style name="MD3Button" parent="Widget.Material3.Button">
        <item name="cornerRadius">28dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textSize">15sp</item>
    </style>

    <!-- MD3 Tonal Button -->
    <style name="MD3TonalButton" parent="Widget.Material3.Button.TonalButton">
        <item name="cornerRadius">28dp</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <!-- MD3 Card Style: Extra rounded, subtle elevation -->
    <style name="MD3Card" parent="Widget.Material3.CardView.Elevated">
        <item name="cardCornerRadius">28dp</item>
        <item name="cardElevation">1dp</item>
        <item name="cardBackgroundColor">@color/md3_surface</item>
    </style>
</resources>
